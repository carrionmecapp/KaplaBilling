# SKTCOD SIP Platform — permisos sudo para el usuario voxikam
# Copiado por install.sh a /etc/sudoers.d/voxikam
# Validar con: visudo -c -f /etc/sudoers.d/voxikam

# Permite recargar nftables (firewall desde panel web)
voxikam ALL=(ALL) NOPASSWD: /usr/sbin/nft

# Permite recargar dispatcher de Kamailio (cuando se cambia carrier/cliente)
voxikam ALL=(ALL) NOPASSWD: /usr/sbin/kamcmd

# NO se permite ningún otro comando sudo
