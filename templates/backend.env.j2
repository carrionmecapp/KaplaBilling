# SKTCOD SIP Platform — Backend config
# Generado por install.sh — NO editar manualmente (usar gen_configs.py para regenerar)

DATABASE_URL=mysql+aiomysql://{{ db_user }}:{{ db_pass }}@127.0.0.1:{{ db_port }}/{{ db_name }}
DATABASE_URL_SYNC=mysql+pymysql://{{ db_user }}:{{ db_pass }}@127.0.0.1:{{ db_port }}/{{ db_name }}

JWT_SECRET={{ jwt_secret }}
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

PUBLIC_IP={{ public_ip }}
PRIVATE_IP={{ private_ip }}
DOMAIN={{ domain }}
WEB_PORT={{ web_port }}

KAMAILIO_CTL_SOCKET=/var/run/kamailio/kamailio_ctl
DISPATCHER_LIST=/etc/kamailio/dispatcher.list
NFTABLES_D=/etc/nftables.d
NFTABLES_CONF=/etc/nftables.conf

INVOICES_DIR={{ install_dir }}/invoices
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://{{ domain }}:{{ web_port }},http://{{ private_ip }}:{{ web_port }},http://{{ public_ip }}:{{ web_port }}

# HEP3 receiver (mini-Homer) — mismo host que Kamailio normalmente
HEP_HOST=127.0.0.1
HEP_PORT=9060
SIP_TRACE_DAYS=1
